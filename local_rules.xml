<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<group name="disk,syscollector,">
  <rule id="100050" level="10">
    <if_sid>221</if_sid>
    <field name="type">filesystem</field>
    <field name="free" type="pcre2">^[0-9]+$</field>
    <description>Disk space low on agent</description>
  </rule>
</group>

<group name="synology,syslog,">

  <rule id="100200" level="3">
    <decoded_as>synology-dsm-login-success</decoded_as>
    <description>Synology DSM Login erfolgreich - Benutzer $(user) von $(srcip)</description>
    <group>authentication_success,synology,</group>
  </rule>

  <rule id="100201" level="2">
    <decoded_as>synology-smb-share-access</decoded_as>
    <description>Synology SMB-Freigabezugriff - Benutzer $(user) von $(srcip) via $(protocol)</description>
    <group>synology,smb,file_access,</group>
  </rule>

  <rule id="100202" level="5">
    <decoded_as>synology-webdav-event</decoded_as>
    <description>Synology WebDAV $(action) - Benutzer $(user) von $(srcip) auf $(url)</description>
    <group>synology,webdav,file_access,</group>
  </rule>

  <rule id="100203" level="7">
    <decoded_as>synology-smtp-user-changed</decoded_as>
    <description>Synology SMTP-Benutzer geändert durch $(user)</description>
    <group>synology,configuration_change,mail,</group>
  </rule>

  <rule id="100204" level="6">
    <decoded_as>synology-smtp-auth-required</decoded_as>
    <description>Synology SMTP-Authentifizierung erforderlich - gesetzt durch $(user)</description>
    <group>synology,configuration_change,mail,</group>
  </rule>

  <rule id="100205" level="6">
    <decoded_as>synology-smb-log-enabled</decoded_as>
    <description>Synology SMB-Logging aktiviert durch $(user)</description>
    <group>synology,configuration_change,smb,</group>
  </rule>

  <rule id="100206" level="5">
    <decoded_as>synology-smb-loglevel-enabled</decoded_as>
    <description>Synology SMB-Log-Level geändert durch $(user): $(extra_data)</description>
    <group>synology,configuration_change,smb,</group>
  </rule>

  <rule id="100207" level="1">
    <decoded_as>synology-test-message</decoded_as>
    <description>Synology Testmeldung vom Syslog Client von $(srcip)</description>
    <group>synology,test_message,</group>
  </rule>

  <rule id="100208" level="3">
    <decoded_as>synology-system-ddns-registered</decoded_as>
    <description>Synology DDNS registriert - IP $(srcip)</description>
    <group>synology,network,ddns,</group>
  </rule>

  <rule id="100209" level="8">
    <decoded_as>synology-system-email-failed</decoded_as>
    <description>Synology E-Mail-Versand fehlgeschlagen - $(extra_data)</description>
    <group>synology,mail,error,</group>
  </rule>

  <rule id="100210" level="7">
    <decoded_as>synology-system-user-created</decoded_as>
    <description>Synology Benutzer erstellt - $(user)</description>
    <group>synology,user_management,configuration_change,</group>
  </rule>

  <rule id="100211" level="7">
    <decoded_as>synology-system-user-added-group</decoded_as>
    <description>Synology Benutzer $(user) zu Gruppe hinzugefügt - $(extra_data)</description>
    <group>synology,user_management,group_change,</group>
  </rule>

  <rule id="100212" level="9">
    <decoded_as>synology-system-password-changed</decoded_as>
    <description>Synology Passwort geändert - Benutzer $(user)</description>
    <group>synology,user_management,password_change,</group>
  </rule>

  <rule id="100213" level="8">
    <decoded_as>synology-system-app-privilege</decoded_as>
    <description>Synology App-Berechtigung geändert - Benutzer $(user), Aktion $(action)</description>
    <group>synology,privilege_change,configuration_change,</group>
  </rule>

  <rule id="100214" level="5">
    <decoded_as>synology-system-package-state</decoded_as>
    <description>Synology Paketstatus geändert - $(action)</description>
    <group>synology,package_management,</group>
  </rule>

  <rule id="100215" level="4">
    <decoded_as>synology-system-service-bracket-state</decoded_as>
    <description>Synology Dienststatus geändert - $(action)</description>
    <group>synology,service_state,</group>
  </rule>

  <rule id="100216" level="4">
    <decoded_as>synology-system-start-stop</decoded_as>
    <description>Synology Systemdienst $(action)</description>
    <group>synology,service_state,</group>
  </rule>

  <rule id="100217" level="5">
    <decoded_as>synology-system-boot</decoded_as>
    <description>Synology Systemstart erkannt</description>
    <group>synology,system_boot,</group>
  </rule>

  <rule id="100218" level="10">
    <decoded_as>synology-system-low-storage</decoded_as>
    <description>Synology Speicherplatz niedrig - $(extra_data)</description>
    <group>synology,storage,warning,</group>
  </rule>

  <rule id="100299" level="1">
    <decoded_as>synology-system-catchall</decoded_as>
    <description>Synology unbekannter System-Log: $(extra_data)</description>
    <group>synology,unknown,</group>
  </rule>

  <rule id="100300" level="1">
    <decoded_as>synology-user-catchall</decoded_as>
    <description>Synology unbekannter User-Log: $(extra_data)</description>
    <group>synology,unknown,</group>
  </rule>

  <rule id="100301" level="1">
    <decoded_as>synology-package-catchall</decoded_as>
    <description>Synology unbekannter Package-Log: $(extra_data)</description>
    <group>synology,unknown,</group>
  </rule>

  <rule id="100302" level="1">
    <decoded_as>synology-server-catchall</decoded_as>
    <description>Synology unbekannter Server-Log: $(extra_data)</description>
    <group>synology,unknown,</group>
  </rule>

</group>

<!-- =========================
     Synology Drive rules
     ========================= -->

<group name="synology_drive,">

  <rule id="100500" level="0">
    <decoded_as>synology-drive</decoded_as>
    <description>Synology Drive Client Log</description>
  </rule>

  <!-- Generische Fehler niedrig halten -->
  <rule id="100501" level="3">
    <if_sid>100500</if_sid>
    <field name="synology.drive.level">ERROR</field>
    <description>Synology Drive allgemeiner Fehler</description>
  </rule>

  <rule id="100502" level="2">
    <if_sid>100500</if_sid>
    <field name="synology.drive.level">WARNING</field>
    <description>Synology Drive Warnung</description>
  </rule>

  <!-- Verbindung / Sync kritisch -->
  <rule id="100510" level="10">
    <if_sid>100500</if_sid>
    <match>Failed to find connection</match>
    <description>Synology Drive kann keine Verbindung zur Synology herstellen</description>
  </rule>

  <rule id="100511" level="9">
    <if_sid>100500</if_sid>
    <match>failed to connect to server</match>
    <description>Synology Drive Verbindung zum Server fehlgeschlagen</description>
  </rule>

  <rule id="100512" level="9">
    <if_sid>100500</if_sid>
    <match>channel error while connecting to server</match>
    <description>Synology Drive Channel-Fehler beim Verbindungsaufbau</description>
  </rule>

  <rule id="100513" level="8">
    <if_sid>100500</if_sid>
    <match>failed to get server info</match>
    <description>Synology Drive QuickConnect/Server-Info konnte nicht abgerufen werden</description>
  </rule>

  <rule id="100514" level="8">
    <if_sid>100500</if_sid>
    <match>Couldn't resolve host name</match>
    <description>Synology Drive DNS-Auflösung fehlgeschlagen</description>
  </rule>

  <!-- SSL / Zertifikat -->
  <rule id="100520" level="10">
    <if_sid>100500</if_sid>
    <match>SSL peer certificate or SSH remote key was not OK</match>
    <description>Synology Drive SSL-Zertifikatsprüfung fehlgeschlagen</description>
  </rule>

  <rule id="100521" level="10">
    <if_sid>100500</if_sid>
    <match>ERR_SSL_VERIFY_FAIL</match>
    <description>Synology Drive SSL Verify fehlgeschlagen</description>
  </rule>

  <!-- Auth -->
  <rule id="100530" level="10">
    <if_sid>100500</if_sid>
    <match>Invalid password</match>
    <description>Synology Drive Anmeldung fehlgeschlagen: falsches Passwort</description>
  </rule>

  <rule id="100531" level="7">
    <if_sid>100500</if_sid>
    <match>Requires OTP</match>
    <description>Synology Drive Anmeldung benötigt OTP</description>
  </rule>

  <!-- Laufender Sync verliert Verbindung -->
  <rule id="100540" level="9">
    <if_sid>100500</if_sid>
    <match>Failed to send/recv long poll request</match>
    <description>Synology Drive Long-Poll-Verbindung fehlgeschlagen</description>
  </rule>

  <rule id="100541" level="8">
    <if_sid>100500</if_sid>
    <match>Failed to long poll event</match>
    <description>Synology Drive Event-Abfrage fehlgeschlagen, Fallback aktiv</description>
  </rule>

  <rule id="100542" level="8">
    <if_sid>100500</if_sid>
    <match>bio error is set to -2</match>
    <description>Synology Drive Netzwerk-/TLS-Streamfehler</description>
  </rule>

  <!-- Datei-/Sync-Fehler -->
  <rule id="100550" level="8">
    <if_sid>100500</if_sid>
    <match>Failed to prepare file block</match>
    <description>Synology Drive konnte Datei nicht für Upload vorbereiten</description>
  </rule>

  <rule id="100551" level="8">
    <if_sid>100500</if_sid>
    <match>Failed to read file</match>
    <description>Synology Drive konnte lokale Datei nicht lesen</description>
  </rule>

  <rule id="100552" level="5">
    <if_sid>100500</if_sid>
    <match>blocked by common filter</match>
    <description>Synology Drive Datei durch Filterregel blockiert</description>
  </rule>

  <!-- Lokale DB / Client beschädigt -->
  <rule id="100560" level="9">
    <if_sid>100500</if_sid>
    <match>cannot get next</match>
    <description>Synology Drive lokale Datenbank/Session-Tabelle fehlerhaft</description>
  </rule>

  <!-- Auto-Updater nur niedrig -->
  <rule id="100570" level="3">
    <if_sid>100500</if_sid>
    <match>Fail to run auto update</match>
    <description>Synology Drive Auto-Update fehlgeschlagen</description>
  </rule>

  <rule id="100571" level="2">
    <if_sid>100500</if_sid>
    <match>Response is an empty array</match>
    <description>Synology Drive Auto-Updater: kein Update verfügbar oder leere Antwort</description>
  </rule>

<rule id="100590" level="10">
  <match>SYNODRIVE_INACTIVE</match>
  <description>Synology Drive vermutlich pausiert oder inaktiv</description>
</rule>

<rule id="100591" level="3">
  <match>SYNODRIVE_OK</match>
  <description>Synology Drive aktiv</description>
</rule>

<rule id="100592" level="6">
  <match>SYNODRIVE_ERROR</match>
  <description>Keine Synology Drive Logs gefunden</description>
</rule>

</group>
